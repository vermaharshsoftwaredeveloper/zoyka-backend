generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Outlet {
  id                String            @id @default(uuid())
  key               String            @unique
  name              String
  description       String?
  isActive          Boolean           @default(true)
  regionId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ownerId           String?
  address           String?
  categoryId        String?
  monthlyCapacity   Int?
  qualityScore      Float?            @default(0)
  imageUrl          String?
  departmentId      String?
  artisansCount     Int?              @default(0)
  managerId         String?           @unique
  location          String?
  noOfArtisans      Int?
  parentOutletId    String?
  category          Category?         @relation(fields: [categoryId], references: [id])
  department        Department?       @relation(fields: [departmentId], references: [id])
  manager           User?             @relation("OutletManager", fields: [managerId], references: [id])
  owner             User?             @relation("OutletOwner", fields: [ownerId], references: [id])
  region            Region?           @relation(fields: [regionId], references: [id])
  payouts           Payout[]
  products          Product[]
  productionBatches ProductionBatch[]
  bulkInquiries     BulkOrderInquiry[]

  @@index([isActive])
  @@index([regionId])
  @@index([ownerId])
  @@index([departmentId])
  @@index([parentOutletId], map: "Outlet_parentOutletId_index")
}

model Testimonial {
  id               String   @id @default(uuid())
  customerName     String
  customerImageUrl String?
  reviewText       String
  rating           Int
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Float
  minOrderAmount Float?
  maxDiscount    Float?
  startsAt       DateTime?
  expiresAt      DateTime?
  usageLimit     Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  link      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model User {
  id                String                       @id @default(uuid())
  email             String                       @unique
  password          String?
  createdAt         DateTime                     @default(now())
  isEmailVerified   Boolean                      @default(false)
  mobile            String?                      @unique
  name              String
  updatedAt         DateTime                     @updatedAt
  avatar            String?
  otp               String?
  otpExpiry         DateTime?
  otpPurpose        OtpPurpose?
  refreshToken      String?
  role              Role                         @default(USER)
  bankAccountNo     String?
  bankIfscCode      String?
  bankName          String?
  isActive          Boolean                      @default(true)
  joiningDate       DateTime                     @default(now())
  location          String?
  yearsOfExperience Int?
  authProvider      String                       @default("local")
  googleId          String?                      @unique
  addresses          Address[]
  bulkInquiries      BulkOrderInquiry[]
  cart               Cart?
  contactQueries     ContactUsQuery[]
  orders             Order[]
  paymentSessions   PaymentSession[]
  managedOutlet      Outlet?                        @relation("OutletManager")
  ownedOutlets       Outlet[]                     @relation("OutletOwner")
  helpRequests      PaymentDeliveryHelpRequest[]
  productsAsArtisan Product[]                    @relation("ProductArtisan")
  reviews           Review[]
  wishlist          Wishlist[]
  invoices          Invoice[]

  @@index([isEmailVerified])
}

model Product {
  id                String         @id @default(uuid())
  outletId          String?
  title             String
  slug              String         @unique
  description       String?
  stock             Int            @default(0)
  categoryId        String
  averageRating     Float          @default(0)
  totalRatingsCount Int            @default(0)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  artisanId         String
  material          String?
  specialFeatures   String?
  actualPrice       Float
  sellingPrice      Float
  district          String?
  price             Float?
  producerName      String?
  producerStory     String?
  cartItems         CartItem[]
  orders            Order[]
  artisan           User           @relation("ProductArtisan", fields: [artisanId], references: [id])
  category          Category       @relation(fields: [categoryId], references: [id])
  outlet            Outlet?        @relation(fields: [outletId], references: [id])
  images            ProductImage[]
  reviews           Review[]
  wishlist          Wishlist[]

  @@unique([outletId, slug])
  @@index([outletId])
  @@index([artisanId])
  @@index([categoryId])
  @@index([isActive])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id             String        @id @default(uuid())
  userId         String
  productId      String
  rating         Int
  comment        String?
  wouldRecommend Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images         ReviewImage[]

  @@index([userId])
  @@index([productId])
}

model ContactUsQuery {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([createdAt])
}

model BulkOrderInquiry {
  id                String                    @id @default(uuid())
  userId            String?
  outletId          String?
  fullName          String
  companyName       String
  email             String
  phoneNumber       String
  category          String?
  quantityRequired  String
  city              String
  state             String
  pincode           String
  additionalDetails String?
  referenceImage    String?
  status            BulkOrderInquiryStatus    @default(PENDING)
  adminNotes        String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  user              User?                     @relation(fields: [userId], references: [id])
  outlet            Outlet?                   @relation(fields: [outletId], references: [id])

  @@index([email])
  @@index([status])
  @@index([outletId])
  @@index([createdAt])
}

model PaymentDeliveryHelpRequest {
  id                String   @id @default(uuid())
  userId            String?
  referenceId       String
  additionalDetails String
  createdAt         DateTime @default(now())
  user              User?    @relation(fields: [userId], references: [id])

  @@index([referenceId])
  @@index([createdAt])
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model Address {
  id              String           @id @default(uuid())
  userId          String
  type            AddressType      @default(HOME)
  isDefault       Boolean          @default(false)
  fullName        String
  phoneNumber     String
  line1           String
  line2           String?
  landmark        String?
  district        String
  state           String
  pincode         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@index([userId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id                String           @id @default(uuid())
  userId            String
  addressId         String
  productId         String
  paymentSessionId  String?
  status            OrderStatus      @default(PLACED)
  quantity          Int
  unitPrice         Float
  totalAmount       Float
  paymentMethod     String           @default("COD")
  paymentStatus     String           @default("PENDING")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  address           Address          @relation(fields: [addressId], references: [id])
  product           Product          @relation(fields: [productId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentSession    PaymentSession?  @relation(fields: [paymentSessionId], references: [id], onDelete: SetNull)
  invoice           Invoice?

  @@index([userId])
  @@index([addressId])
  @@index([productId])
  @@index([status])
  @@index([paymentSessionId])
}

model PaymentSession {
  id                    String   @id @default(uuid())
  userId                String
  addressId             String
  amount                Float
  currency              String   @default("INR")
  paymentMethod         String
  status                String   @default("PENDING")
  cashfreeOrderId       String   @unique
  cashfreeOrderToken    String?
  cashfreePaymentLink   String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  orders                Order[]
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([cashfreeOrderId])
}

model Region {
  id           String      @id @default(uuid())
  name         String      @unique
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  departmentId String?
  district     String
  state        String
  regionHead   String?
  outlets      Outlet[]
  department   Department? @relation(fields: [departmentId], references: [id])

  @@unique([name, district])
}

model Category {
  id           String      @id @default(uuid())
  name         String      @unique
  slug         String      @unique
  description  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  departmentId String?
  imageUrl     String?
  department   Department? @relation(fields: [departmentId], references: [id])
  outlets      Outlet[]
  products     Product[]

  @@index([isActive])
  @@index([departmentId])
}

model ProductionBatch {
  id            String   @id @default(uuid())
  outletId      String
  title         String?
  unitCount     Int
  qualityStatus String   @default("PENDING")
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  outlet        Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model Payout {
  id          String   @id @default(uuid())
  outletId    String
  amount      Float    @default(0)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  commission  Float    @default(0)
  grossAmount Float    @default(0)
  ordersCount Int      @default(0)
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model SettingConfig {
  id        String   @id @default(uuid())
  category  String
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categories  Category[]
  outlets     Outlet[]
  regions     Region[]

  @@index([isActive])
}

enum Role {
  USER
  ADMIN
  MANAGER
  PRODUCER
  ARTISAN
  FARMER
  KITCHEN
}

enum OtpPurpose {
  SIGNUP
  LOGIN
  PASSWORD_RESET
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum OrderStatus {
  PAYMENT_PENDING
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum BulkOrderInquiryStatus {
  PENDING
  IN_PROGRESS
  CONTACTED
  COMPLETED
  REJECTED
}

model Invoice {
  id              String   @id @default(uuid())
  orderId         String   @unique
  invoiceNumber   String   @unique
  userId          String
  productPrice    Float
  quantity        Int
  subtotal        Float
  shippingCharge  Float    @default(0)
  gstPercent      Float    @default(0)
  gstAmount       Float    @default(0)
  couponCode      String?
  couponDiscount  Float    @default(0)
  totalAmount     Float
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([invoiceNumber])
}
